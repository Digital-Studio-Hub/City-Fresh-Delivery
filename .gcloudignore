# .gcloudignore file for Cloud Build
# Skip unnecessary files during build

# Git
.git
.gitignore

# Node
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Development
.env.local
.env.*.local
.replit
replit.md

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# CI/CD
.github/
.circleci/

# Build artifacts (will be rebuilt)
dist/
build/

# Attached assets
attached_assets/

# Documentation
*.md
